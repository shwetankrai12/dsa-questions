# ── Google OAuth (for user authentication) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Supabase (for progress persistence) ──
SUPABASE_URL=
# Service-role key — bypasses RLS, never expose to browser
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Session (OAuth state only — short-lived) ──
SESSION_SECRET=

# ── JWT (user auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
JWT_SECRET=

# ── URLs ──
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001

# ── Environment ──
NODE_ENV=development
PORT=3001
